#!/usr/bin/env bash
# commit-msg hook: enforce runtime provenance prefix on commit subjects.
#
# Per CLAUDE.md "Commit conventions" and the global CLAUDE.md "Commit provenance
# tag" rule, every commit subject MUST start with one of the recognized runtime
# prefixes. This hook rejects (non-zero exit) any commit-msg whose first line
# does not match the prefix list, with a clear message pointing at the spec.
#
# Recognized prefixes (canonical list — keep in sync with global CLAUDE.md):
#   claude/<model-id>:    Claude Code native session
#   claudem/<model-id>:   MiniMax CLI / MiniMax-M3 family
#   claudew/<model-id>:   Wafer CLI / GLM family
#   gemini/<model-id>:    Gemini CLI
#   codex/<model-id>:     Codex CLI
#   cursor/<model>:       Cursor / OpenCode
#   ao/<model>:           Agent Orchestrator worker
#   human:                Human-authored commit
#
# Wired via:  git config core.hooksPath .githooks
# Standalone: bash .githooks/commit-msg <path-to-commit-msg-file>
# Bypass:     git commit --no-verify  (escape hatch for emergency fixes only)
#
# Bead: ez-gh-actions-jcie

set -euo pipefail

COMMIT_MSG_FILE="${1:-}"
if [ -z "$COMMIT_MSG_FILE" ] || [ ! -f "$COMMIT_MSG_FILE" ]; then
  echo "commit-msg hook: missing or unreadable commit-msg file: '$COMMIT_MSG_FILE'" >&2
  exit 2
fi

# Read the FIRST non-comment, non-blank line. git commit-msg files may begin
# with comments (#) — git strips them on commit but we still see them in $1
# during the hook. Use the first non-comment, non-blank line as the subject.
subject="$(awk '
  /^[[:space:]]*$/ { next }       # blank line: skip
  /^[[:space:]]*#/ { next }       # comment line: skip
  { print; exit }
' "$COMMIT_MSG_FILE")"

if [ -z "$subject" ]; then
  echo "commit-msg hook: empty commit subject (after skipping comments/blanks)" >&2
  exit 2
fi

# Allowed prefixes — anchored at start of subject, terminated by ':'.
# Keep this list in lockstep with global CLAUDE.md "Commit provenance tag" table.
#
# `human:` has no model segment (per CLAUDE.md example `human: <subject>`), so
# it gets its own exact-match regex. Every other runtime prefix REQUIRES a
# `/<model-id>` segment before the ':' — the slash and model-id are NOT
# optional, otherwise bare "claude: fix" (no model) or "humane: tweak" (word
# that merely starts with "human") would incorrectly pass.
allowed_re='^(claude|claudem|claudew|gemini|codex|cursor|ao)/[a-zA-Z0-9._-]+:[[:space:]]'
human_re='^human:[[:space:]]'

# Merge commits are produced by git itself and should be allowed through
# regardless of exact wording (the individual squash commits inside the merge
# were each validated at their own commit-msg hook invocation; the merge
# commit's provenance is the human/operator that pushed the merge). Covers:
#   Merge branch 'foo' into main
#   Merge remote-tracking branch 'origin/main'
#   Merge tag 'v1.2.3'
#   Merge commit 'abc123' into main
#   Merge pull request #66 from jleechanorg/some-branch
merge_re='^Merge (remote-tracking )?(branch|tag|commit) '
merge_pr_re='^Merge pull request #[0-9]+ '

if [[ "$subject" =~ $allowed_re ]]; then
  exit 0
fi

if [[ "$subject" =~ $human_re ]]; then
  exit 0
fi

if [[ "$subject" =~ $merge_re ]] || [[ "$subject" =~ $merge_pr_re ]]; then
  exit 0
fi

cat >&2 <<EOF
commit-msg hook: REJECTED — subject lacks runtime provenance prefix.

  subject: $subject

Per CLAUDE.md "Commit conventions" and the global CLAUDE.md "Commit provenance
tag" rule, every commit subject MUST start with one of:

  claude/<model-id>:    Claude Code native
  claudem/<model-id>:   MiniMax / MiniMax-M3 family
  claudew/<model-id>:   Wafer / GLM family
  gemini/<model-id>:    Gemini CLI
  codex/<model-id>:     Codex CLI
  cursor/<model>:       Cursor / OpenCode
  ao/<model>:           Agent Orchestrator worker
  human:                Human-authored

Examples:
  claude/sonnet: chore(hooks): add commit-msg provenance gate
  human: fix: typo in README

Bypass (emergency only):  git commit --no-verify
Reference bead:            ez-gh-actions-jcie
EOF
exit 1