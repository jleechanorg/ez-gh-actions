\n201\t    }\n202\t    if plat.os == \"linux\" {\n203\t        return Backend::DockerSysbox; // assume Sysbox is installed or will be\n204\t    }\n205\t    Backend::Docker\n206\t}\n207\t`src/config.rs`\n208\tuse crate::platform::Platform;\n209\tuse crate::backend::Backend;\n210\tuse anyhow::Result;\n211\t\n212\tpub fn generate(plat: &Platform, backend: &Backend) -> Result<()> {\n213\t    let config = match backend {\n214\t        Backend::Tart | Backend::Libvirt => {\n215\t            // VM backends get per-VM resource limits\n216\t            format!(\n217\t                r#\"\n218\trunners:\n219\t  default:\n220\t    backend: {}\n221\t    labels: [self-hosted, {}]\n222\t    count: 2\n223\t    resources:\n224\t      memory: 4G\n225\t      cpus: 2\n226\t\"#,\n227\t                if *backend == Backend::Tart { \"tart\" } else { \"libvirt\" },\n228\t                plat.os\n229\t            )\n230\t        }\n231\t        _ => {\n232\t            // Docker path with resource limits\n233\t            r#\"\n234\trunners:\n235\t  default:\n236\t    backend: docker\n237\t    labels: [self-hosted, docker]\n238\t    count: 2\n239\t    docker:\n240\t      memory: 4g\n241\t      cpus: 2\n242\t      pids_limit: 100\n243\t\"#\n244\t            .to_string()\n245\t        }\n246\t    };\n247\t\n248\t    std::fs::write(\"outrunner.yml\", config)?;\n249\t    println!(\"Generated outrunner.yml\");"}]}, "uuid": "53e77761-8850-4c8c-9812-c0daf6c0e958", "timestamp": "2026-07-03T22:01:35.260Z", "sourceToolAssistantUUID": "59b44a0a-05ae-4675-9f35-7bf79a4a7414", "userType": "external", "entrypoint": "cli", "cwd": "/home/jleechan/projects/worktree_runner", "sessionId": "8ca589dd-8422-44b1-a543-52bd7b71f14b", "version": "2.1.198", "gitBranch": "fix/linux-runner-pre-job-hook", "slug": "velvet-wishing-cake"}
