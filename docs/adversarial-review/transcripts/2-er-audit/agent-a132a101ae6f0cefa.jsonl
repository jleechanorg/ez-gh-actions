{"parentUuid": "c1bacb54-a0c8-4945-87be-a86af7713f48", "isSidechain": true, "promptId": "6c3a0b22-aa71-4abe-86b8-7ed7f2e35c75", "agentId": "a132a101ae6f0cefa", "type": "user", "message": {"role": "user", "content": [{"tool_use_id": "toolu_016NNcV4ZZMnL7kNBeJGHHuU", "type": "tool_result", "content": "1\tuse anyhow::{bail, Context, Result};\n2\tuse serde::Deserialize;\n3\tuse std::process::Command;\n4\t\n5\tuse crate::config::{GithubConfig, Scope};\n6\t\n7\t/// All GitHub API access goes through the `gh` CLI so we inherit its auth\n8\t/// (keyring/oauth) instead of handling tokens ourselves. v1 requirement:\n9\t/// `gh auth login` must have been run for the target.\n10\tfn api_base(gh: &GithubConfig) -> String {\n11\t    match gh.scope {\n12\t        Scope::Repo => format!(\"repos/{}\", gh.target),\n13\t        Scope::Org => format!(\"orgs/{}\", gh.target),\n14\t    }\n15\t}\n16\t\n17\t#[derive(Debug, Deserialize)]\n18\tstruct JitConfigResponse {\n19\t    encoded_jit_config: String,\n20\t    runner: JitRunner,\n21\t}\n22\t\n23\t#[derive(Debug, Deserialize)]\n24\tstruct JitRunner {\n25\t    id: u64,\n26\t    name: String,\n27\t}\n28\t\n29\t/// Ask GitHub for a just-in-time runner registration. A JIT runner accepts\n30\t/// exactly one job and then deregisters itself \u2014 ephemeral by construction,\n31\t/// no registration token to store or clean up.\n32\tpub fn generate_jitconfig(\n33\t    gh: &GithubConfig,\n34\t    name: &str,\n35\t    labels: &[String],\n36\t) -> Result<(String, u64)> {\n37\t    let path = format!(\"{}/actions/runners/generate-jitconfig\", api_base(gh));\n38\t    let mut cmd = Command::new(\"gh\");\n39\t    cmd.args([\"api\", \"-X\", \"POST\", &path, \"-f\", &format!(\"name={name}\")]);\n40\t    cmd.args([\"-F\", \"runner_group_id=1\"]);\n41\t    for label in labels {\n42\t        cmd.args([\"-f\", &format!(\"labels[]={label}\")]);\n43\t    }\n44\t    let out = cmd\n45\t        .output()\n46\t        .context(\"failed to run `gh api` \u2014 is the gh CLI installed?\")?;\n47\t    if !out.status.success() {\n48\t        bail!(\n49\t            \"gh api generate-jitconfig failed for {}: {}\",\n50\t            gh.target,\n51\t            String::from_utf8_lossy(&out.stderr)\n52\t        );\n53\t    }\n54\t    let parsed: JitConfigResponse =\n55\t        serde_json::from_slice(&out.stdout).context(\"unexpected generate-jitconfig response\")?;\n56\t    let _ = parsed.runner.name;\n57\t    Ok((parsed.encoded_jit_config, parsed.runner.id))\n58\t}\n59\t\n60\t#[derive(Debug, Deserialize)]\n61\tpub struct RunnerInfo {\n62\t    pub id: u64,\n63\t    pub name: String,\n64\t    pub status: String,\n65\t    pub busy: bool,\n66\t}\n67\t\n68\t#[derive(Debug, Deserialize)]\n69\tstruct RunnerList {\n70\t    runners: Vec<RunnerInfo>,\n71\t}\n72\t\n73\tpub fn list_runners(gh: &GithubConfig) -> Result<Vec<RunnerInfo>> {\n74\t    let path = format!(\"{}/actions/runners?per_page=100\", api_base(gh));\n75\t    let out = Command::new(\"gh\")\n76\t        .args([\"api\", &path])\n77\t        .output()\n78\t        .context(\"failed to run `gh api`\")?;\n79\t    if !out.status.success() {\n80\t        bail!(\n81\t            \"gh api list runners failed: {}\",\n82\t            String::from_utf8_lossy(&out.stderr)\n83\t        );\n84\t    }\n85\t    let parsed: RunnerList = serde_json::from_slice(&out.stdout)?;\n86\t    Ok(parsed.runners)\n87\t}\n88\t\n89\t/// Best-effort removal of a registered runner (used when we kill a runner\n90\t/// container before it ever picked up a job).\n91\tpub fn remove_runner(gh: &GithubConfig, id: u64) -> Result<()> {\n92\t    let path = format!(\"{}/actions/runners/{id}\", api_base(gh));\n93\t    let out = Command::new(\"gh\")\n94\t        .args([\"api\", \"-X\", \"DELETE\", &path])\n95\t        .output()\n96\t        .context(\"failed to run `gh api`\")?;\n97\t    if !out.status.success() {\n98\t        bail!(\n99\t            \"gh api remove runner {id} failed: {}\",\n100\t            String::from_utf8_lossy(&out.stderr)\n101\t        );\n102\t    }\n103\t    Ok(())\n104\t}\n105\t\n106\tpub fn gh_auth_ok() -> bool {\n107\t    Command::new(\"gh\")\n108\t        .args([\"auth\", \"status\"])\n109\t        .output()\n110\t        .map(|o| o.status.success())\n111\t        .unwrap_or(false)\n112\t}\n113\t"}]}, "uuid": "6f9a3e00-5bc4-4b8f-92e2-a733e2c363c6", "timestamp": "2026-07-03T22:21:20.143Z", "sourceToolAssistantUUID": "c1bacb54-a0c8-4945-87be-a86af7713f48", "userType": "external", "entrypoint": "cli", "cwd": "/home/jleechan/projects/worktree_runner", "sessionId": "8ca589dd-8422-44b1-a543-52bd7b71f14b", "version": "2.1.198", "gitBranch": "fix/linux-runner-pre-job-hook", "slug": "velvet-wishing-cake"}
