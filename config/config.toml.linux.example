# jeff-ubuntu fleet — 10 runners.
# Install: cp config/config.toml.linux.example ~/.config/ezgha/config.toml
version = 1

[github]
scope = "org"
target = "jleechanorg"

[runner]
name_prefix = "ez-runner-c"
labels = ["self-hosted", "self-hosted-mikey", "ezgha", "Linux", "X64"]
count = 10
image = "ezgha-runner:latest"

[limits]
memory_mb = 3000
cpus = 2.0
pids = 512
min_free_disk_gb = 10

[policy]
# Native linux docker = container isolation. "vm" only if daemon is VM-contained
# and you want fail-closed enforcement when backend drops below vm.
minimum_isolation = "container"
