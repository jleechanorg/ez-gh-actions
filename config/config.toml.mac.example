# MacBook fleet — 6 runners, Colima-backed docker.
# Install: cp config/config.toml.mac.example ~/.config/ezgha/config.toml
version = 1

[github]
scope = "org"
target = "jleechanorg"

[runner]
labels = ["self-hosted", "self-hosted-mikey", "ezgha", "macOS", "ARM64"]
count = 6
image = "ezgha-runner:latest"
name_prefix = "ez-mac-runner-b"
# Opt-in shared pip wheelhouse (bead jleechan-93cf): mounted read-only into
# every runner container at /opt/wheelhouse with PIP_FIND_LINKS pointed at
# it, so pip installs stop writing their whole download into the ephemeral
# container's writable overlay layer every job. Populate the directory
# yourself (e.g. `pip download -r requirements.txt -d <dir>` on a schedule);
# if the path doesn't exist the mount is silently skipped (fail-open).
#
# CRITICAL on Colima/Mac: this path MUST live under one of Colima's
# configured virtiofs mounts (check `colima ssh -- mount | grep virtiofs`
# for the current allowlist -- e.g. ~/.cache, ~/Library/Caches/colima,
# ~/.local/share/worldarchitect-runners). A path OUTSIDE that allowlist
# does NOT fail loudly: `docker run -v <unmounted-host-path>:...` silently
# bind-mounts an empty phantom directory instead (confirmed live,
# 2026-07-17/18) -- the daemon's own is_dir() check on the HOST side still
# passes (the real directory exists on macOS), so the mount is attempted,
# but PIP_FIND_LINKS ends up pointing at an empty dir inside the container
# and pip quietly falls through to a normal network download, looking
# "configured" while doing nothing. Use a subdirectory of ~/.cache, not an
# arbitrary path like ~/.ezgha/wheelhouse.
# wheelhouse_host_path = "/Users/jleechan/.cache/ezgha-wheelhouse"

[limits]
memory_mb = 8192
cpus = 4.0
pids = 512
min_free_disk_gb = 10

[policy]
# Colima = docker-in-VM, but backend isolation is still "container".
# Do NOT set "vm" here — serve fail-closes on daemon blips.
minimum_isolation = "container"
