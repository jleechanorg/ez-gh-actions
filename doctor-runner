#!/usr/bin/env bash
# doctor.sh — ez-gh-actions fleet health check. Read-only.
# Outputs a one-shot human-readable report; --json emits machine-parseable
# status for the loop agent (or a follow-up Claude Code session) to drive
# iteration. Designed to fail loudly on the things that previously caused
# silent fleet decay (slot-file desync, missing daemons, container/reg drift).
set -euo pipefail

# --- arg parsing ---------------------------------------------------------
JSON=0
DETAIL=0
PROVE=0
for a in "$@"; do
  case "$a" in
    --json) JSON=1 ;;
    --detail|-v|--verbose) DETAIL=1 ;;
    --prove) PROVE=1 ;;   # dispatch a live canary job and verify it runs on our fleet
    -h|--help)
      echo "usage: doctor.sh [--prove] [--detail]"
      echo "  --prove   dispatch a live ezgha-selftest and verify it runs on the configured runner prefix (adds ~1-2 min)"
      echo "  --detail  verbose output"
      echo "env: LOOP_WINDOW (min, default 3), ROUTING_N (runs, default 6), ORG, EZGHA_REPO"
      exit 0 ;;
    *) echo "unknown arg: $a" >&2; exit 2 ;;
  esac
done

ORG="${ORG:-jleechanorg}"
EZGHA_REPO="${EZGHA_REPO:-jleechanorg/ez-gh-actions}"
QUEUE_REPO="${QUEUE_REPO:-jleechanorg/worldarchitect.ai}"
QUEUE_TAIL_WARN_MIN="${QUEUE_TAIL_WARN_MIN:-20}"
STALE_HOURS="${STALE_HOURS:-8}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- helpers -------------------------------------------------------------
section() { printf '\n=== %s ===\n' "$*"; }
ok() { printf '  [OK]   %s\n' "$*"; }
warn() { printf '  [WARN] %s\n' "$*"; }
bad() { printf '  [BAD]  %s\n' "$*"; }
info() { printf '  [..]   %s\n' "$*"; }

# Platform detection: the same fleet can run on Linux (systemd) or macOS
# (launchd) and the diagnostic surfaces differ accordingly. Detect ONCE at
# the top so downstream sections branch consistently.
case "$(uname -s)" in
  Linux)  PLATFORM="linux" ;;
  Darwin) PLATFORM="macos" ;;
  *)      PLATFORM="other" ;;
esac

# Probe the supervisor (systemd on Linux, launchd on macOS) for ezgha's
# service state. Returns one of: active | inactive | failed | not-loaded.
probe_service_state() {
  if [ "$PLATFORM" = "linux" ]; then
    systemctl --user is-active ezgha.service 2>/dev/null || echo "inactive"
  elif [ "$PLATFORM" = "macos" ]; then
    # launchctl prints `PID STATUS LABEL` per loaded job. The ezgha label is
    # `org.jleechanorg.ezgha`. PID column "-" with STATUS "0" means loaded
    # but not running; any other STATUS is the last exit code.
    local line
    line=$(launchctl list 2>/dev/null | awk '$3 == "org.jleechanorg.ezgha" {print; exit}')
    if [ -z "$line" ]; then
      echo "not-loaded"
      return
    fi
    local pid status
    pid=$(echo "$line" | awk '{print $1}')
    status=$(echo "$line" | awk '{print $2}')
    if [ -n "$pid" ] && [ "$pid" != "-" ]; then
      echo "active"
    elif [ "$status" = "0" ]; then
      echo "inactive"
    else
      echo "failed"
    fi
  else
    echo "unsupported"
  fi
}

# Read the last N minutes of ezgha service logs. On Linux this is journalctl;
# on macOS the launchd supervisor writes to /tmp/ezgha-launchd-stdout.log and
# stderr.log (see src/service.rs install_launchd).
recent_logs() {
  local _since_min="${1:-3}"
  if [ "$PLATFORM" = "linux" ]; then
    journalctl --user -u ezgha.service --since "${_since_min} minutes ago" --no-pager 2>/dev/null
  elif [ "$PLATFORM" = "macos" ]; then
    if [ -f /tmp/ezgha-launchd-stdout.log ]; then
      tail -n 200 /tmp/ezgha-launchd-stdout.log
    fi
    if [ -f /tmp/ezgha-launchd-stderr.log ]; then
      tail -n 200 /tmp/ezgha-launchd-stderr.log
    fi
  fi
}

# --- A. local daemon + service ------------------------------------------
section "1. ezgha service"
SERVICE_STATE=$(probe_service_state)
case "$SERVICE_STATE" in
  active)   ok "ezgha.service = active ($PLATFORM)" ;;
  inactive) bad "ezgha.service = inactive (expected active) — start with: ezgha install-service" ;;
  failed)   bad "ezgha.service = failed — check recent logs" ;;
  not-loaded) bad "ezgha.service = not-loaded — run: ezgha install-service" ;;
  unsupported) warn "ezgha.service = unsupported (unknown platform: $PLATFORM)" ;;
  *)        bad "ezgha.service = $SERVICE_STATE (expected active)" ;;
esac

section "2. docker daemon"
if DOCKER_INFO=$(docker info --format '{{.ServerVersion}} {{.NCPU}} {{.MemTotal}}' 2>&1); then
  ok "docker daemon reachable (version/cpu/mem: $DOCKER_INFO)"
else
  bad "docker daemon unreachable: $DOCKER_INFO"
fi

section "3. colima VM (the daemon's host)"
# Two ways to enumerate running colima/Lima VMs:
#   - `colima list` — macOS only, shows ALL profiles by name (default, ci, etc.).
#   - `limactl list` — Linux + macOS, but only shows profiles named `colima`
#     (not `default`). On a fresh Mac install the active profile is named
#     `default`, NOT `colima`, so a pure `limactl list` probe missed it (the
#     original bug this section fixed). Probe both.
COLIMA_STATUS="NotInstalled"
if command -v colima >/dev/null 2>&1; then
  # colima's `list` columns: PROFILE STATUS ARCH CPUS MEMORY DISK RUNTIME ADDRESS
  any_running=$(colima list 2>/dev/null | awk 'NR>1 && $2 == "Running" {print $2; exit}')
  any_stopped=$(colima list 2>/dev/null | awk 'NR>1 && $2 == "Stopped" {print $2; exit}')
  if [ -n "$any_running" ]; then
    ok "colima VM running (at least one profile)"
    COLIMA_STATUS="Running"
  elif [ -n "$any_stopped" ]; then
    # Before declaring BAD: the stopped profile may be the old 'default' colima
    # profile while the actual Docker daemon runs via a limactl VM named 'colima'.
    # Check limactl first, then fall back to whether Docker is actually reachable.
    lima_running_fallback=""
    if command -v limactl > /dev/null 2>&1; then
      lima_running_fallback=$(limactl list 2>/dev/null | awk 'NR>1 && $2 == "Running" {print; exit}')
    fi
    if [ -n "$lima_running_fallback" ]; then
      ok "colima VM running via limactl (colima 'default' profile stopped but limactl VM active)"
      COLIMA_STATUS="Running"
    elif DOCKER_VER=$(docker info --format '{{.ServerVersion}}' 2>/dev/null) && [ -n "$DOCKER_VER" ]; then
      warn "colima profile stopped but docker daemon reachable (v$DOCKER_VER) — non-Lima backend in use"
      COLIMA_STATUS="Running"
    else
      bad "colima VM stopped — start with: colima start"
      COLIMA_STATUS="Stopped"
    fi
  elif command -v limactl >/dev/null 2>&1; then
    # Fallback to limactl if colima list has no running/stopped profiles (e.g. named 'colima')
    lima_running=$(limactl list 2>/dev/null | awk 'NR>1 && $2 == "Running" {print; exit}')
    lima_stopped=$(limactl list 2>/dev/null | awk 'NR>1 && $2 == "Stopped" {print; exit}')
    if [ -n "$lima_running" ]; then
      ok "lima VM running"
      COLIMA_STATUS="Running"
    elif [ -n "$lima_stopped" ]; then
      bad "lima VM stopped — start with: limactl start <name>"
      COLIMA_STATUS="Stopped"
    else
      info "colima installed but no profiles, and limactl installed but no running VMs (host uses Docker or remote daemon)"
    fi
  else
    info "colima installed but no profiles (host uses Docker Desktop or a remote daemon)"
  fi
elif command -v limactl >/dev/null 2>&1; then
  # Linux-side fallback: limactl list is the only Lima enumeration.
  lima_running=$(limactl list 2>/dev/null | awk 'NR>1 && $2 == "Running" {print; exit}')
  lima_stopped=$(limactl list 2>/dev/null | awk 'NR>1 && $2 == "Stopped" {print; exit}')
  if [ -n "$lima_running" ]; then
    ok "lima VM running"
    COLIMA_STATUS="Running"
  elif [ -n "$lima_stopped" ]; then
    bad "lima VM stopped — start with: limactl start <name>"
    COLIMA_STATUS="Stopped"
  else
    info "limactl installed but no running VMs (host uses Docker or remote daemon)"
  fi
else
  info "neither colima nor limactl installed (this host uses Docker Desktop or a remote daemon)"
fi

# --- B. ezgha runtime state ---------------------------------------------
section "4. ezgha runtime state"
SERVICE_RSS=$(ps -o rss= -p $(pgrep -f 'ezgha serve' 2>/dev/null | head -1) 2>/dev/null || echo "?")
info "binary PID RSS=${SERVICE_RSS} KB"
# Count ensure_count failures in a TIME window. ezgha logs roughly one line
# per 30s; on Linux `journalctl --since N minutes ago` is exact, on macOS we
# fall back to `tail -n 200` over /tmp/ezgha-launchd-{stdout,stderr}.log and
# approximate. Health means CURRENT health: only the last LOOP_WINDOW minutes
# of recent activity count.
LOOP_WINDOW="${LOOP_WINDOW:-3}"
LOOP_FAILS=$(recent_logs "$LOOP_WINDOW" | grep -c 'ensure_count failed' || true)
LAST_LOOP=$(recent_logs "$LOOP_WINDOW" | tail -n 1 | cut -c1-40 || true)
info "ensure_count failed occurrences in last ${LOOP_WINDOW} min: $LOOP_FAILS"
info "most recent log line: $LAST_LOOP"
SLOT_FILE="$HOME/.config/ezgha/slot_assignments.toml"
if [ -f "$SLOT_FILE" ]; then
  ASSIGNED=$(grep -c '=' "$SLOT_FILE" 2>/dev/null || echo 0)
  ok "slot_assignments.toml present ($ASSIGNED slots reserved)"
else
  info "slot_assignments.toml absent (no reservations)"
fi

# Read the configured runner name prefix from ~/.config/ezgha/config.toml.
# Different platforms/stacks use different prefixes: jeff-ubuntu Linux uses
# `ez-org-runner` (legacy) or `ez-runner-b` (after prefix rename PR #8143),
# Mac uses `ez-mac-runner` and may collide so suffixes like `-b` get added
# by next_slot to avoid GitHub-side 422s. The doctor must accept ALL of
# these, not a single hardcoded `ez-org-`.
RUNNER_NAME_PREFIX=$(awk -F'"' '/^name_prefix/ {print $2; exit}' "$HOME/.config/ezgha/config.toml" 2>/dev/null)
if [ -z "$RUNNER_NAME_PREFIX" ]; then
  # Legacy / missing config: fall back to `ez-org-runner` (the pre-#8143 default).
  RUNNER_NAME_PREFIX="ez-org-runner"
fi
info "configured runner name prefix: $RUNNER_NAME_PREFIX"


# Policy vs backend: catch minimum_isolation=vm on hosts where docker blips
# leave backend at container-only (Mac colima socket flake → serve fail-closed).
POLICY_MIN=$(awk -F'"' '/^minimum_isolation/ {print $2; exit}' "$HOME/.config/ezgha/config.toml" 2>/dev/null)
if [ -n "$POLICY_MIN" ]; then
  info "configured minimum_isolation: $POLICY_MIN"
  if recent_logs 10 | grep -q 'policy requires vm isolation but best available backend is docker'; then
    bad "serve fail-closed: minimum_isolation=$POLICY_MIN but docker backend is container-only (daemon blip or misconfig)"
  elif [ "$POLICY_MIN" = "vm" ] && [ "$PLATFORM" = "macos" ] && ! docker info --format '{{.KernelVersion}}' >/dev/null 2>&1; then
    bad "minimum_isolation=vm but docker daemon/kernel probe failed — serve will refuse to spawn"
  else
    ok "isolation policy $POLICY_MIN compatible with current docker backend"
  fi
fi

# --- B2. GitHub App token freshness --------------------------------------
# The daemon and every gh-CLI call below auth via a GitHub App installation
# token minted by scripts/mint_gh_app_token.py and refreshed by
# scripts/refresh_gh_app_token.sh into ~/.config/ezgha/gh_token. That token's
# real TTL is ~60 minutes (see bead ez-gh-actions-hcu incident: a launchd
# refresh job hung 52+ min, the token expired, and every GitHub API call
# started 401ing, draining the Mac fleet to 0/6). Catch a stale/expired/
# missing token HERE, before section 5's gh api calls below silently return
# truncated/empty data that looks like a fleet problem instead of an auth one.
section "4b. GitHub App token freshness"
GH_TOKEN_PATH="$HOME/.config/ezgha/gh_token"
GH_TOKEN_STALE_CRITICAL=0
GH_TOKEN_STATUS="unknown"
GH_TOKEN_AGE_MIN="?"
if [ ! -f "$GH_TOKEN_PATH" ]; then
  bad "gh_token missing at $GH_TOKEN_PATH — refresh_gh_app_token.sh has never run or the file was deleted"
  GH_TOKEN_STATUS="missing"
  GH_TOKEN_STALE_CRITICAL=1
else
  # Portable mtime: GNU stat (Linux) vs BSD stat (macOS) — mirror the
  # PLATFORM branching already used elsewhere in this script (recent_logs,
  # probe_service_state) rather than a blind fallback chain.
  if [ "$PLATFORM" = "macos" ]; then
    GH_TOKEN_MTIME=$(stat -f %m "$GH_TOKEN_PATH" 2>/dev/null || echo 0)
  else
    GH_TOKEN_MTIME=$(stat -c %Y "$GH_TOKEN_PATH" 2>/dev/null || echo 0)
  fi
  if [ "${GH_TOKEN_MTIME:-0}" -gt 0 ] 2>/dev/null; then
    GH_TOKEN_NOW=$(date +%s)
    GH_TOKEN_AGE_MIN=$(( (GH_TOKEN_NOW - GH_TOKEN_MTIME) / 60 ))
    if [ "$GH_TOKEN_AGE_MIN" -lt 45 ]; then
      ok "gh_token fresh (age ${GH_TOKEN_AGE_MIN}m, TTL ~60m)"
      GH_TOKEN_STATUS="fresh"
    elif [ "$GH_TOKEN_AGE_MIN" -le 60 ]; then
      warn "gh_token getting stale (age ${GH_TOKEN_AGE_MIN}m, TTL ~60m) — refresh should fire soon"
      GH_TOKEN_STATUS="warn"
    else
      bad "gh_token STALE (age ${GH_TOKEN_AGE_MIN}m > 60m TTL) — token is expired/expiring; GitHub API calls will 401 (see bead ez-gh-actions-hcu)"
      GH_TOKEN_STATUS="stale"
      GH_TOKEN_STALE_CRITICAL=1
    fi
  else
    bad "gh_token mtime unreadable at $GH_TOKEN_PATH (stat failed on platform=$PLATFORM)"
    GH_TOKEN_STATUS="stat_failed"
    GH_TOKEN_STALE_CRITICAL=1
  fi
fi
# Live 200-check: mtime alone cannot detect a token that LOOKS fresh (young
# mtime, under the 45min TTL window) but is cryptographically dead — the
# exact jleechan-wzk root cause: a cached ghs_ token survives an app
# private-key rotation with a perfectly fresh mtime, but every API call
# using it 401s, because the signature is bound to a key that no longer
# validates. Every other `gh api` call in this script rides the OPERATOR's
# ambient `gh auth` (see `gh auth status` — usually a personal token), not
# ezgha's own app token, so none of them actually exercise gh_token's
# validity; explicitly override GH_TOKEN for this one call so it tests what
# section 4b claims to test.
if [ -f "$GH_TOKEN_PATH" ] && { [ "$GH_TOKEN_STATUS" = "fresh" ] || [ "$GH_TOKEN_STATUS" = "warn" ]; }; then
  # awk NR==1 (no exit) consumes gh's full output — `| head -1` here made gh
  # take SIGPIPE under pipefail and killed the whole script with exit 141.
  GH_TOKEN_LIVE_HTTP=$(GH_TOKEN="$(cat "$GH_TOKEN_PATH" 2>/dev/null)" gh api -i "orgs/$ORG/actions/runners?per_page=1" 2>/dev/null | awk 'NR==1{print $2}')
  if [ "$GH_TOKEN_LIVE_HTTP" = "200" ]; then
    ok "gh_token live-check: 200 against orgs/$ORG/actions/runners (mtime freshness confirmed by a real call, not just a clock)"
  else
    bad "gh_token live-check FAILED: mtime says '$GH_TOKEN_STATUS' (age ${GH_TOKEN_AGE_MIN}m) but a live API call using this exact token returned HTTP ${GH_TOKEN_LIVE_HTTP:-<no response>}, not 200 — token is cryptographically dead (likely signed by a rotated-out private key, see bead jleechan-wzk) even though its mtime looks fine"
    GH_TOKEN_STATUS="live_check_failed"
    GH_TOKEN_STALE_CRITICAL=1
  fi
fi
if [ "$JSON" = "1" ]; then
  info "gh_token_status=$GH_TOKEN_STATUS gh_token_age_min=$GH_TOKEN_AGE_MIN gh_token_stale_critical=$GH_TOKEN_STALE_CRITICAL"
fi

# --- C. GitHub-side runner fleet ----------------------------------------
section "5. GitHub org runner fleet ($ORG)"
RAW=$($(command -v gh) api "orgs/$ORG/actions/runners" --paginate 2>/dev/null || echo '{"runners":[]}')
TOTAL=$(echo "$RAW" | jq '.total_count // (.runners | length)')
ONLINE=$(echo "$RAW" | jq '[.runners[] | select(.status=="online")] | length')
OFFLINE=$(echo "$RAW" | jq '[.runners[] | select(.status=="offline")] | length')
BUSY=$(echo "$RAW" | jq '[.runners[] | select(.busy==true)] | length')
echo "  total=$TOTAL online=$ONLINE offline=$OFFLINE busy=$BUSY"
EZ_RUNNERS=$(echo "$RAW" | jq -r --arg pfx "$RUNNER_NAME_PREFIX" '.runners[] | select(.name | startswith($pfx)) | "\(.name) \(.status)"')
if [ -n "$EZ_RUNNERS" ]; then
  echo "$EZ_RUNNERS" | while read -r n s; do
    case "$s" in
      online) ok "ezgha: $n $s" ;;
      *)      bad "ezgha: $n $s" ;;
    esac
  done
else
  bad "no ${RUNNER_NAME_PREFIX}-* registrations on GitHub"
fi
COLIMA_RUNNERS=$(echo "$RAW" | jq -r '.runners[] | select(.name | startswith("org-runner-")) | "\(.name) \(.status)"')
if [ -n "$COLIMA_RUNNERS" ]; then
  echo "  (colima leftovers still present, not auto-cleaned by ezgha):"
  echo "$COLIMA_RUNNERS" | while read -r n s; do
    warn "colima: $n $s"
  done
fi

# --- D. live docker containers ------------------------------------------
section "6. live docker containers (ezgha-managed)"
CONTAINER_NAMES=$(docker ps --filter label=ezgha=managed --format '{{.Names}} {{.Status}}' 2>/dev/null || true)
CONTAINER_COUNT=$(docker ps --filter label=ezgha=managed --format '{{.Names}}' 2>/dev/null | wc -l)
CONTAINER_COUNT=$(printf '%d' "$CONTAINER_COUNT" 2>/dev/null || echo 0)
info "managed containers running: $CONTAINER_COUNT (expected: configured runner.count)"
echo "$CONTAINER_NAMES" | head -20

# --- E. recent routing proof: jobs REALLY ran on the configured fleet -----
# "online" is not "working". This section proves recent GitHub Actions jobs
# were actually EXECUTED by configured-prefix runners by reading each run's
# jobs API and confirming the runner_name that handled it belongs to our
# fleet. A completed run whose runner_name does not match RUNNER_NAME_PREFIX
# means the job went to a retired fleet / GitHub-hosted / somewhere else.
section "7. real job-execution proof (last ${ROUTING_N:-6} ezgha-selftest runs)"
ROUTING_N="${ROUTING_N:-6}"
REAL_ON_FLEET=0
REAL_TOTAL=0
while read -r rid; do
  [ -z "$rid" ] && continue
  REAL_TOTAL=$((REAL_TOTAL+1))
  jobs=$($(command -v gh) api "repos/$EZGHA_REPO/actions/runs/$rid/jobs" 2>/dev/null)
  rn=$(echo "$jobs" | jq -r '.jobs[0].runner_name // "?"' 2>/dev/null)
  conc=$(echo "$jobs" | jq -r '.jobs[0].conclusion // "?"' 2>/dev/null)
  if [[ "$rn" == "${RUNNER_NAME_PREFIX}"* ]] || [[ "$rn" == "${RUNNER_NAME_PREFIX}-"* ]]; then
    ok "run $rid: $conc on $rn (our fleet)"
    [ "$conc" = "success" ] && REAL_ON_FLEET=$((REAL_ON_FLEET+1))
  else
    warn "run $rid: $conc on $rn (NOT ${RUNNER_NAME_PREFIX}-*)"
  fi
done < <($(command -v gh) run list -R "$EZGHA_REPO" -w ezgha-selftest -L "$ROUTING_N" --json databaseId --jq '.[].databaseId' 2>/dev/null)
info "real jobs succeeded on our fleet: $REAL_ON_FLEET / $REAL_TOTAL"

# --- E2. optional live canary: dispatch a job and prove it runs NOW ------
# `--prove` dispatches a fresh ezgha-selftest and blocks until it completes,
# then confirms the runner_name matches the configured prefix and conclusion=success.
# This is the strongest "handled for real, right now" proof.
CANARY_OK=""
if [ "$PROVE" = "1" ]; then
  section "7b. live canary (dispatch + verify a job runs on our fleet NOW)"
  before=$($(command -v gh) run list -R "$EZGHA_REPO" -w ezgha-selftest -L 1 --json databaseId --jq '.[0].databaseId // 0' 2>/dev/null)
  $(command -v gh) workflow run ezgha-selftest -R "$EZGHA_REPO" >/dev/null 2>&1
  info "dispatched canary; waiting for a new run to appear + complete (up to 180s)..."
  cid=""
  for _ in $(seq 1 18); do
    sleep 10
    latest=$($(command -v gh) run list -R "$EZGHA_REPO" -w ezgha-selftest -L 1 --json databaseId --jq '.[0].databaseId // 0' 2>/dev/null)
    [ "$latest" != "$before" ] && [ "$latest" != "0" ] && { cid="$latest"; break; }
  done
  if [ -z "$cid" ]; then
    bad "canary never appeared — dispatch failed or no runner picked it up"
  else
    for _ in $(seq 1 18); do
      st=$($(command -v gh) run view "$cid" -R "$EZGHA_REPO" --json status,conclusion --jq '.status' 2>/dev/null)
      [ "$st" = "completed" ] && break
      sleep 10
    done
    jobs=$($(command -v gh) api "repos/$EZGHA_REPO/actions/runs/$cid/jobs" 2>/dev/null)
    rn=$(echo "$jobs" | jq -r '.jobs[0].runner_name // "?"')
    conc=$(echo "$jobs" | jq -r '.jobs[0].conclusion // "?"')
    if { [[ "$rn" == "${RUNNER_NAME_PREFIX}" ]] || [[ "$rn" == "${RUNNER_NAME_PREFIX}-"* ]]; } && [ "$conc" = "success" ]; then
      ok "canary run $cid: success on $rn — fleet is handling real jobs NOW"
      CANARY_OK=1
    else
      bad "canary run $cid: $conc on $rn (expected success on ${RUNNER_NAME_PREFIX}-*)"
    fi
  fi
fi


# --- F1b. cross-repo JOB map (single fetch, reused by sections 8, 9, 10) --
# Built BEFORE section 8 so the queue-tail gate can trigger on JOB-level
# waits instead of RUN-level age. A workflow RUN can sit "queued" for 30+
# minutes at run level purely from `concurrency:` serialization or staged
# gate workflows (Green Gate) while every actual JOB gets a runner within
# seconds — observed 2026-07-10 01:11: run 29060462908 was run-level queued
# 33.4m, yet its only job was created at 01:11:49 and picked up immediately
# (33 minutes of concurrency wait, zero runner wait). Run age is NOT runner
# wait; job created_at -> now on status=queued jobs is. This is the SAME
# fetch section 10 previously made — moved, not duplicated, so total API
# call count is unchanged.
EXPLICIT_WORK_REPOS="${EXPLICIT_WORK_REPOS:-jleechanorg/worldarchitect.ai jleechanorg/ez-gh-actions}"
RUNNER_JOB_INDEX_FILE=$(mktemp "${TMPDIR:-/tmp}/ezgha-doctor-jobmap.XXXXXX" 2>/dev/null || echo "/tmp/ezgha-doctor-jobmap.$$")
trap 'rm -f "$RUNNER_JOB_INDEX_FILE"' EXIT

iso_elapsed_min() {
  # Minutes elapsed since an ISO-8601 timestamp ("?" on parse failure).
  python3 -c "
import sys, datetime
try:
    s = datetime.datetime.fromisoformat(sys.argv[1].replace('Z', '+00:00'))
    now = datetime.datetime.now(datetime.timezone.utc)
    print(f'{(now - s).total_seconds() / 60:.1f}')
except Exception:
    print('?')
" "$1" 2>/dev/null
}

build_runner_job_index() {
  # Emits one JSON object per queued/in-progress job across all
  # EXPLICIT_WORK_REPOS. Fresh-only: runs older than STALE_HOURS (section
  # 8's freshness rule, default 8h) are queue zombies, not live work —
  # skipping them ALSO bounds the per-run jobs-API fan-out.
  local repo status runs_json jobs_json rid run_url fresh_cutoff
  if [ "$PLATFORM" = "macos" ]; then
    fresh_cutoff=$(date -u -v-"${STALE_HOURS:-8}"H +%Y-%m-%dT%H:%M:%SZ 2>/dev/null)
  else
    fresh_cutoff=$(date -u -d "${STALE_HOURS:-8} hours ago" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null)
  fi
  for repo in $EXPLICIT_WORK_REPOS; do
    for status in in_progress queued; do
      runs_json=$(gh api "repos/$repo/actions/runs?status=$status&per_page=50" 2>/dev/null) || continue
      while IFS=$'\t' read -r rid run_url; do
        [ -z "$rid" ] && continue
        jobs_json=$(gh api "repos/$repo/actions/runs/$rid/jobs" 2>/dev/null) || continue
        printf '%s' "$jobs_json" | jq -c --arg repo "$repo" --arg run_url "$run_url" \
          '.jobs[]? | select(.status=="in_progress" or .status=="queued")
           | {runner_name, job_name: .name, status, repo: $repo, run_url: $run_url, html_url, started_at, created_at}' 2>/dev/null
      done < <(printf '%s' "$runs_json" | jq -r --arg cutoff "${fresh_cutoff:-}" \
        '.workflow_runs[]? | select($cutoff == "" or .created_at > $cutoff) | [.id, .html_url] | @tsv' 2>/dev/null)
    done
  done
}
set +e
build_runner_job_index | jq -s 'unique_by(.html_url)' > "$RUNNER_JOB_INDEX_FILE" 2>/dev/null
set -e
[ -s "$RUNNER_JOB_INDEX_FILE" ] || echo '[]' > "$RUNNER_JOB_INDEX_FILE"

# Job-level queue counts — computed from the SAME single fetch above
# (fresh-only), never a second API sweep. Section 8's QUEUE_* variables are
# run-level and single-repo; these are job-level across every repo the
# fleet serves, and are what the section-8 tail gate and section-9
# starvation gate trigger on.
set +e
JOBLEVEL_QUEUED_COUNT=$(jq '[.[] | select(.status=="queued")] | length' "$RUNNER_JOB_INDEX_FILE" 2>/dev/null)
JOBLEVEL_INPROG_COUNT=$(jq '[.[] | select(.status=="in_progress")] | length' "$RUNNER_JOB_INDEX_FILE" 2>/dev/null)
JOBLEVEL_OLDEST_QUEUED_AT=$(jq -r '[.[] | select(.status=="queued")] | sort_by(.created_at) | first | .created_at // empty' "$RUNNER_JOB_INDEX_FILE" 2>/dev/null)
set -e
JOBLEVEL_QUEUED_COUNT="${JOBLEVEL_QUEUED_COUNT:-0}"
JOBLEVEL_INPROG_COUNT="${JOBLEVEL_INPROG_COUNT:-0}"
JOBLEVEL_OLDEST_QUEUED_MIN="0"
[ -n "${JOBLEVEL_OLDEST_QUEUED_AT:-}" ] && JOBLEVEL_OLDEST_QUEUED_MIN=$(iso_elapsed_min "$JOBLEVEL_OLDEST_QUEUED_AT")

# --- F2. GitHub Actions queue health (saturation / tail latency) ----------
QUEUE_TAIL_BAD=0
QUEUE_QUEUED_STALE=0
if [ -f "$SCRIPT_DIR/scripts/queue-health.sh" ]; then
  set +e
  # shellcheck source=/dev/null
  source "$SCRIPT_DIR/scripts/queue-health.sh"
  QUEUE_RC=$?
  set -e
  [ "$QUEUE_RC" -eq 1 ] && QUEUE_TAIL_BAD=1
else
  section "8. GitHub Actions queue health"
  warn "scripts/queue-health.sh missing — queue metrics skipped"
fi

# --- F3. per-slot LOCAL execution proof (no GitHub API — the API lies under
# rate limit; see ez-gh-actions-yrt/g3o) --------------------------------
# "online" and "busy" per the GitHub API can be stale or simply unreachable
# during a rate-limit window (exactly the condition this doctor gate exists
# to catch). The only ground truth that cannot lie is the local docker
# daemon: a container is either running or it isn't, and inside a running
# container the GitHub Actions runner either has a `Runner.Worker` process
# (EXECUTING a job right now) or it doesn't (`Runner.Listener` only ->
# IDLE, waiting for work). This section enumerates every CONFIGURED slot —
# not just however many containers happen to exist — so a slot that never
# got a container at all (DOWN) is reported by name, not silently absent.
section "9. per-slot activity truth (docker top, LOCAL-ONLY) — EXECUTING/IDLE-OK/IDLE-STARVED/DOWN"
CONFIGURED_COUNT=$(awk -F'=' '/^count/ {gsub(/[^0-9]/,"",$2); print $2; exit}' "$HOME/.config/ezgha/config.toml" 2>/dev/null)
CONFIGURED_COUNT="${CONFIGURED_COUNT:-16}"
HOST_LABEL="$PLATFORM ($(hostname -s 2>/dev/null || hostname))"

classify_local_slot() {
  # Echoes one of: DOWN | IDLE | EXECUTING for container name "$1".
  local name="$1" running
  running=$(docker inspect -f '{{.State.Running}}' "$name" 2>/dev/null || echo "false")
  if [ "$running" != "true" ]; then
    echo "DOWN"
    return
  fi
  # `docker top` requires PID as first -eo field on docker 27+; the bare
  # `-eo cmd` form silently fails ("Couldn't find PID field in ps output")
  # and would falsely report every slot as IDLE — masking real EXECUTING
  # state. Use `comm` (process basename) instead; it shows "Runner.Worker".
  if docker top "$name" -eo pid,comm 2>/dev/null | grep -qw Worker; then
    echo "EXECUTING"
  else
    echo "IDLE"
  fi
}

DOWN_SLOTS=()
IDLE_SLOTS=()
EXECUTING_SLOTS=()
for _i in $(seq 1 "$CONFIGURED_COUNT"); do
  _name="${RUNNER_NAME_PREFIX}-${_i}"
  case "$(classify_local_slot "$_name")" in
    DOWN)      DOWN_SLOTS+=("$_name") ;;
    IDLE)      IDLE_SLOTS+=("$_name") ;;
    EXECUTING) EXECUTING_SLOTS+=("$_name") ;;
  esac
done

# DOWN persistence (2-sample rule): ephemeral slots naturally blink for
# 20-35s per job cycle (container destroyed after each job, respawned on the
# next serve tick). A single-sample DOWN therefore reads a HEALTHY recycling
# fleet as broken — observed 2026-07-09 post-deploy on jeff-ubuntu: 5 "DOWN"
# slots, all Up again within 20s. Worse, a false DOWN feeds the restart
# remediation advice at the end of this script — a self-outage risk (see
# CLAUDE.md Self-Outage Prevention Principle). DOWN only counts when it
# persists across two samples >= DOWN_PERSISTENCE_WAIT_SECONDS apart
# (default 30s, > one serve tick); slots that recover in between are a
# normal ephemeral recycle, classified by their second-sample state.
DOWN_PERSISTENCE_WAIT_SECONDS="${DOWN_PERSISTENCE_WAIT_SECONDS:-30}"
if [ "${#DOWN_SLOTS[@]}" -gt 0 ]; then
  info "first-pass DOWN candidates (${DOWN_SLOTS[*]}) — re-sampling in ${DOWN_PERSISTENCE_WAIT_SECONDS}s to filter normal ephemeral recycling"
  sleep "$DOWN_PERSISTENCE_WAIT_SECONDS"
  _PERSISTENT_DOWN=()
  _BLINKED=()
  for _name in "${DOWN_SLOTS[@]}"; do
    case "$(classify_local_slot "$_name")" in
      DOWN)      _PERSISTENT_DOWN+=("$_name") ;;
      IDLE)      IDLE_SLOTS+=("$_name");      _BLINKED+=("$_name") ;;
      EXECUTING) EXECUTING_SLOTS+=("$_name"); _BLINKED+=("$_name") ;;
    esac
  done
  if [ "${#_BLINKED[@]}" -gt 0 ]; then
    info "recycled normally (respawned within ${DOWN_PERSISTENCE_WAIT_SECONDS}s, NOT a defect): ${_BLINKED[*]}"
  fi
  DOWN_SLOTS=()
  if [ "${#_PERSISTENT_DOWN[@]}" -gt 0 ]; then
    DOWN_SLOTS=("${_PERSISTENT_DOWN[@]}")
  fi
fi
info "$HOST_LABEL slots (local proof): ${#EXECUTING_SLOTS[@]} executing, ${#IDLE_SLOTS[@]} idle, ${#DOWN_SLOTS[@]} down (of $CONFIGURED_COUNT configured)"

# IDLE is only a defect (IDLE-STARVED) once the queue has been non-empty for
# at least IDLE_STARVED_THRESHOLD_MIN minutes — a single-tick queue blip (job
# just created, not yet picked up) is not starvation. Starvation inputs are
# JOB-level (from the section-F1b job map): a run-level queued age includes
# concurrency-serialization and staged-gate wait, which false-alarms exactly
# like the section-8 tail gate did (2026-07-10 run 29060462908: 33.4m
# run-queued, zero runner wait). JOBLEVEL_OLDEST_QUEUED_MIN is how long the
# oldest fresh queued JOB has actually been waiting for a runner — the
# correct sustained-duration signal. Falls back to section 8's run-level
# values only if the job-map lookup produced no usable number. DOWN is
# always a defect regardless of queue state.
IDLE_STARVED_THRESHOLD_MIN="${IDLE_STARVED_THRESHOLD_MIN:-5}"
STARVE_QUEUED_COUNT="${JOBLEVEL_QUEUED_COUNT:-${QUEUE_QUEUED_FRESH:-0}}"
STARVE_OLDEST_MIN="${JOBLEVEL_OLDEST_QUEUED_MIN:-${QUEUE_OLDEST_FRESH_AGE_MIN:-0}}"
[ "$STARVE_OLDEST_MIN" = "?" ] && STARVE_OLDEST_MIN="${QUEUE_OLDEST_FRESH_AGE_MIN:-0}"
STARVED_PRESENT=0
if [ "${STARVE_QUEUED_COUNT:-0}" -gt 0 ] && awk -v a="${STARVE_OLDEST_MIN:-0}" -v t="$IDLE_STARVED_THRESHOLD_MIN" 'BEGIN{exit !(a>=t)}'; then
  STARVED_PRESENT=1
fi

SLOT_PROOF_CRITICAL=0
if [ "${#DOWN_SLOTS[@]}" -gt 0 ]; then
  bad "DOWN (no container) — ${#DOWN_SLOTS[@]} slot(s): ${DOWN_SLOTS[*]}"
  SLOT_PROOF_CRITICAL=$((SLOT_PROOF_CRITICAL + ${#DOWN_SLOTS[@]}))
fi
if [ "${#IDLE_SLOTS[@]}" -gt 0 ]; then
  if [ "$STARVED_PRESENT" -eq 1 ]; then
    bad "IDLE-STARVED (${STARVE_QUEUED_COUNT} jobs queued, oldest job waiting ${STARVE_OLDEST_MIN}m >= ${IDLE_STARVED_THRESHOLD_MIN}m threshold) — ${#IDLE_SLOTS[@]} slot(s): ${IDLE_SLOTS[*]}"
    SLOT_PROOF_CRITICAL=$((SLOT_PROOF_CRITICAL + ${#IDLE_SLOTS[@]}))
  elif [ "${STARVE_QUEUED_COUNT:-0}" -gt 0 ]; then
    info "IDLE-OK (${STARVE_QUEUED_COUNT} job(s) queued ${STARVE_OLDEST_MIN}m < ${IDLE_STARVED_THRESHOLD_MIN}m threshold, not yet starved): ${IDLE_SLOTS[*]}"
  else
    info "IDLE-OK (nothing queued): ${IDLE_SLOTS[*]}"
  fi
fi
[ "${#EXECUTING_SLOTS[@]}" -gt 0 ] && ok "EXECUTING right now: ${EXECUTING_SLOTS[*]}"

# --- F4. EXPLICIT-WORK INVENTORY (every Configured slot, every machine) --
# The user's bar is concrete: list each runner's job OR say the queue has no
# pending items — no excuses. We map every EXECUTING slot to the actual
# GitHub Actions run it's working on (via the org-runners list and the
# workflow_run's runner_id field), AND we list the slots that are *idle*
# alongside their reason (queue empty vs. queued without an available slot).
# All from local-truth sources; no GitHub API counts.
section "10. EXPLICIT-WORK INVENTORY (every config'd runner, every machine)"
EXPLICIT_WORK_HOST="${EXPLICIT_WORK_HOST:-macbook}"
# Ground truth for "what job is this runner executing" is the per-run JOBS
# API (repos/{repo}/actions/runs/{run_id}/jobs), which carries runner_name
# directly. The workflow-RUN object has NO runner_id/runner_name field at
# all (verified against a live in-progress run 2026-07-09) — the prior
# implementation joined on `.runner_id` against run objects, which does not
# exist, so the join silently never matched and every EXECUTING slot fell
# through to the "no run mapped" placeholder regardless of real activity.
# We enumerate runs with status in_progress AND queued (queued runs can hold
# in-progress jobs and vice versa) on the repos our fleet actually serves,
# then each fresh run's jobs, into ONE temp-file job map indexed by
# runner_name — joined per-slot below, never one API call per slot.
# NOTE: the job map itself ($RUNNER_JOB_INDEX_FILE) and the JOBLEVEL_*
# counts are built ONCE in section F1b (before section 8) so the queue-tail
# and starvation gates can trigger on job-level waits; this section only
# consumes them.
SECTION10_DOWN_RESAMPLE_SECONDS="${SECTION10_DOWN_RESAMPLE_SECONDS:-25}"
info "job map: ${JOBLEVEL_INPROG_COUNT} in-progress + ${JOBLEVEL_QUEUED_COUNT} queued fresh job(s) across: $EXPLICIT_WORK_REPOS"

job_evidence_for_runner() {
  # Prints "<job name> | started <ISO time> (<elapsed>m ago) | <run html_url>"
  # or nothing if no in-progress job in the map matches this runner_name.
  local name="$1" rec job_name run_url started_at elapsed_min
  rec=$(jq -c --arg n "$name" 'first(.[] | select(.runner_name==$n and .status=="in_progress")) // empty' "$RUNNER_JOB_INDEX_FILE" 2>/dev/null)
  [ -z "$rec" ] && return 0
  job_name=$(printf '%s' "$rec" | jq -r '.job_name')
  run_url=$(printf '%s' "$rec" | jq -r '.run_url // .html_url')
  started_at=$(printf '%s' "$rec" | jq -r '.started_at // .created_at')
  elapsed_min=$(iso_elapsed_min "$started_at")
  printf '%s | started %s (%sm ago) | %s' "$job_name" "$started_at" "${elapsed_min:-?}" "$run_url"
}
probe_slot_state() {
  # Echoes DOWN | IDLE | EXECUTING for container "$2" on host "$1"
  # (localhost = local docker, anything else = ssh).
  local host="$1" name="$2" running work
  if [ "$host" = "localhost" ]; then
    running=$(docker inspect -f '{{.State.Running}}' "$name" 2>/dev/null || echo false)
  else
    running=$(ssh -o ConnectTimeout=4 "$host" "docker inspect -f '{{.State.Running}}' '$name' 2>/dev/null || echo false")
  fi
  if [ "$running" != "true" ]; then
    echo "DOWN"
    return
  fi
  if [ "$host" = "localhost" ]; then
    set +e; docker top "$name" -eo pid,comm 2>/dev/null | grep -qw Worker; work=$?; set -e
  else
    set +e; ssh -o ConnectTimeout=4 "$host" "docker top '$name' -eo pid,comm 2>/dev/null | grep -qw Worker" >/dev/null 2>&1; work=$?; set -e
  fi
  if [ "$work" -eq 0 ]; then echo "EXECUTING"; else echo "IDLE"; fi
}

list_slot_work() {
  # Aligned table, one row per configured slot:
  #   <slot>  <STATE>  <job name> | started <ISO time> (<elapsed>m ago) | <run html_url>
  # Two passes so the single 25s DOWN re-sample (bead ez-gh-actions-b895)
  # happens ONCE per host, and rows still print in slot order: pass 1
  # classifies every slot; first-pass DOWN candidates are re-probed after
  # SECTION10_DOWN_RESAMPLE_SECONDS — a slot that is back Up on the second
  # sample is CYCLING (normal ephemeral respawn, NOT a critical defect);
  # only a DOWN that persists both samples prints as DOWN. Pass 2 renders.
  local prefix="$1" count="$2" host="${3:-localhost}" label="$4"
  printf "\n  %s (%d configured):\n" "$label" "$count"
  local -a slot_state=()
  local i name jobline has_down=0
  for i in $(seq 1 "$count"); do
    slot_state[i]=$(probe_slot_state "$host" "${prefix}-${i}")
    [ "${slot_state[i]}" = "DOWN" ] && has_down=1
  done
  if [ "$has_down" -eq 1 ]; then
    info "$label: first-pass DOWN candidate(s) — re-sampling once in ${SECTION10_DOWN_RESAMPLE_SECONDS}s to filter normal ephemeral recycling (bead ez-gh-actions-b895)"
    sleep "$SECTION10_DOWN_RESAMPLE_SECONDS"
    for i in $(seq 1 "$count"); do
      [ "${slot_state[i]}" != "DOWN" ] && continue
      case "$(probe_slot_state "$host" "${prefix}-${i}")" in
        DOWN) : ;;                                # persisted both samples — stays DOWN
        *)    slot_state[i]="CYCLING" ;;          # back Up — normal respawn, not a defect
      esac
    done
  fi
  local exec_n=0 idl=0 dn=0 cyc=0
  printf "    %-22s %-13s %s\n" "SLOT" "STATE" "EVIDENCE"
  for i in $(seq 1 "$count"); do
    name="${prefix}-${i}"
    case "${slot_state[i]:-DOWN}" in
      EXECUTING)
        exec_n=$((exec_n+1))
        set +e
        jobline=$(job_evidence_for_runner "$name")
        set -e
        if [ -z "$jobline" ]; then
          # Runner.Worker process is running (local ground truth) but no
          # in-progress job in the map matched this runner_name yet.
          jobline="picked up in last ~60s (job-map lag or API truncation; Runner.Worker pid is ground truth)"
        fi
        printf "    %-22s %-13s %s\n" "$name" "EXECUTING" "$jobline"
        ;;
      IDLE)
        idl=$((idl+1))
        # 4-state model: IDLE-OK (nothing queued, or queued but under the
        # sustained-starvation threshold) vs IDLE-STARVED (queue has been
        # non-empty for >= IDLE_STARVED_THRESHOLD_MIN minutes — see section 9).
        if [ "${STARVED_PRESENT:-0}" -eq 1 ]; then
          printf "    %-22s %-13s %s\n" "$name" "IDLE-STARVED" "${STARVE_QUEUED_COUNT} fresh queued jobs, oldest job waiting ${STARVE_OLDEST_MIN}m >= ${IDLE_STARVED_THRESHOLD_MIN}m threshold"
        elif [ "${STARVE_QUEUED_COUNT:-0}" -gt 0 ]; then
          printf "    %-22s %-13s %s\n" "$name" "IDLE-OK" "${STARVE_QUEUED_COUNT} job(s) queued ${STARVE_OLDEST_MIN}m < ${IDLE_STARVED_THRESHOLD_MIN}m threshold (not yet starved)"
        else
          printf "    %-22s %-13s %s\n" "$name" "IDLE-OK" "nothing queued"
        fi
        ;;
      CYCLING)
        cyc=$((cyc+1))
        printf "    %-22s %-13s %s\n" "$name" "CYCLING" "respawned within one tick (blinked between samples ${SECTION10_DOWN_RESAMPLE_SECONDS}s apart — not a defect; bead ez-gh-actions-b895)"
        ;;
      DOWN)
        dn=$((dn+1))
        printf "    %-22s %-13s %s\n" "$name" "DOWN" "no container (persisted both samples ${SECTION10_DOWN_RESAMPLE_SECONDS}s apart — critical)"
        ;;
    esac
  done
  printf "  %s totals: %d executing, %d idle, %d cycling, %d down  (of %d configured)\n" "$label" "$exec_n" "$idl" "$cyc" "$dn" "$count"
}

# Local fleet — whichever host this script is actually running on (was
# hardcoded "LINUX (jeff-ubuntu)" regardless of $PLATFORM, so running this
# ON the Mac mislabeled the Mac's own fleet as Linux's — fixed to report the
# true local host so evidence provenance is never ambiguous).
LOCAL_PREFIX="${RUNNER_NAME_PREFIX:-ez-runner-c}"
LOCAL_COUNT="${CONFIGURED_COUNT:-16}"
list_slot_work "$LOCAL_PREFIX" "$LOCAL_COUNT" "localhost" "$HOST_LABEL"

# Remote fleet (SSH) — the OTHER half of the two-host fleet. Only when
# reachable. Never dead when unreachable.
if [ "$PLATFORM" = "macos" ]; then
  REMOTE_HOST="${REMOTE_LINUX_HOST:-jeff-ubuntu}"
  REMOTE_PREFIX="${REMOTE_LINUX_PREFIX:-ez-runner-c}"
  REMOTE_COUNT="${REMOTE_LINUX_COUNT:-16}"
  REMOTE_LABEL="linux ($REMOTE_HOST)"
else
  REMOTE_HOST="${EXPLICIT_WORK_HOST:-macbook}"
  REMOTE_PREFIX="${MAC_RUNNER_NAME_PREFIX:-ez-mac-runner-b}"
  REMOTE_COUNT="${MAC_RUNNER_COUNT:-6}"
  REMOTE_LABEL="macos ($REMOTE_HOST)"
fi
if timeout 5 ssh -o ConnectTimeout=4 -o BatchMode=yes "$REMOTE_HOST" true >/dev/null 2>&1; then
  list_slot_work "$REMOTE_PREFIX" "$REMOTE_COUNT" "$REMOTE_HOST" "$REMOTE_LABEL"
else
  printf "\n  %s: not reachable via SSH — per-slot work inventory skipped\n" "$REMOTE_LABEL"
fi

# Remote-fleet probe via SSH, for the verdict's SLOT_PROOF_CRITICAL count —
# best-effort, never fatal if unreachable. Uses the same REMOTE_HOST/PREFIX/
# COUNT resolved above (macos->jeff-ubuntu when running on the Mac,
# linux->macbook when running on Linux) so DOWN/STARVED counting is
# symmetric regardless of which host doctor-runner is invoked from — was
# previously hardcoded to always SSH to "macbook", which silently omitted
# jeff-ubuntu's DOWN/STARVED slots from the verdict when run on the Mac.
if timeout 5 ssh -o ConnectTimeout=4 -o BatchMode=yes "$REMOTE_HOST" true >/dev/null 2>&1; then
  REMOTE_DOWN_SLOTS=()
  REMOTE_IDLE_SLOTS=()
  REMOTE_EXECUTING_SLOTS=()
  REMOTE_REPORT=$(timeout 20 ssh -o ConnectTimeout=4 -o BatchMode=yes "$REMOTE_HOST" "
    for i in \$(seq 1 $REMOTE_COUNT); do
      name=\"${REMOTE_PREFIX}-\${i}\"
      running=\$(docker inspect -f '{{.State.Running}}' \"\$name\" 2>/dev/null || echo false)
      if [ \"\$running\" != true ]; then echo \"\$name DOWN\"; continue; fi
      if docker top \"\$name\" -eo pid,comm 2>/dev/null | grep -qw Worker; then
        echo \"\$name EXECUTING\"
      else
        echo \"\$name IDLE\"
      fi
    done
  " 2>/dev/null || true)
  while read -r _name _state; do
    [ -z "$_name" ] && continue
    case "$_state" in
      DOWN)      REMOTE_DOWN_SLOTS+=("$_name") ;;
      IDLE)      REMOTE_IDLE_SLOTS+=("$_name") ;;
      EXECUTING) REMOTE_EXECUTING_SLOTS+=("$_name") ;;
    esac
  done <<< "$REMOTE_REPORT"
  # Same 2-sample DOWN-persistence rule as the local pass (see section 9):
  # re-probe only the DOWN candidates after one serve tick; a slot that came
  # back is a normal ephemeral recycle, not a defect.
  if [ "${#REMOTE_DOWN_SLOTS[@]}" -gt 0 ]; then
    info "$REMOTE_LABEL first-pass DOWN candidates (${REMOTE_DOWN_SLOTS[*]}) — re-sampling in ${DOWN_PERSISTENCE_WAIT_SECONDS}s"
    sleep "$DOWN_PERSISTENCE_WAIT_SECONDS"
    _R_PERSISTENT=()
    _R_BLINKED=()
    for _name in "${REMOTE_DOWN_SLOTS[@]}"; do
      _state2=$(timeout 20 ssh -o ConnectTimeout=4 -o BatchMode=yes "$REMOTE_HOST" "
        running=\$(docker inspect -f '{{.State.Running}}' '$_name' 2>/dev/null || echo false)
        if [ \"\$running\" != true ]; then echo DOWN
        elif docker top '$_name' -eo pid,comm 2>/dev/null | grep -qw Worker; then echo EXECUTING
        else echo IDLE; fi
      " 2>/dev/null || echo DOWN)
      case "$_state2" in
        DOWN)      _R_PERSISTENT+=("$_name") ;;
        IDLE)      REMOTE_IDLE_SLOTS+=("$_name");      _R_BLINKED+=("$_name") ;;
        EXECUTING) REMOTE_EXECUTING_SLOTS+=("$_name"); _R_BLINKED+=("$_name") ;;
      esac
    done
    if [ "${#_R_BLINKED[@]}" -gt 0 ]; then
      info "$REMOTE_LABEL recycled normally (respawned within ${DOWN_PERSISTENCE_WAIT_SECONDS}s, NOT a defect): ${_R_BLINKED[*]}"
    fi
    REMOTE_DOWN_SLOTS=()
    if [ "${#_R_PERSISTENT[@]}" -gt 0 ]; then
      REMOTE_DOWN_SLOTS=("${_R_PERSISTENT[@]}")
    fi
  fi
  info "$REMOTE_LABEL slots (remote proof via ssh): ${#REMOTE_EXECUTING_SLOTS[@]} executing, ${#REMOTE_IDLE_SLOTS[@]} idle, ${#REMOTE_DOWN_SLOTS[@]} down (of $REMOTE_COUNT configured)"
  if [ "${#REMOTE_DOWN_SLOTS[@]}" -gt 0 ]; then
    bad "$REMOTE_LABEL DOWN (no container) — ${#REMOTE_DOWN_SLOTS[@]} slot(s): ${REMOTE_DOWN_SLOTS[*]}"
    SLOT_PROOF_CRITICAL=$((SLOT_PROOF_CRITICAL + ${#REMOTE_DOWN_SLOTS[@]}))
  fi
  if [ "${#REMOTE_IDLE_SLOTS[@]}" -gt 0 ] && [ "${STARVED_PRESENT:-0}" -eq 1 ]; then
    bad "$REMOTE_LABEL IDLE-STARVED (oldest queued job ${STARVE_OLDEST_MIN}m >= ${IDLE_STARVED_THRESHOLD_MIN}m threshold) — ${#REMOTE_IDLE_SLOTS[@]} slot(s): ${REMOTE_IDLE_SLOTS[*]}"
    SLOT_PROOF_CRITICAL=$((SLOT_PROOF_CRITICAL + ${#REMOTE_IDLE_SLOTS[@]}))
  fi
else
  warn "$REMOTE_LABEL not reachable via SSH — skipping remote per-slot proof"
fi

# Serve-loop-starvation signal: the largest gap between respawn bursts, plus
# how often the monitor tick is hitting a rate limit. This is the direct
# observable for the ez-gh-actions-yrt/g3o starvation bug (a 60-90s+ gap
# here means ensure_count is being starved by a rate-limited monitor tick
# again, regardless of what the per-slot proof above shows this instant).
# Linux-only: journalctl timestamps every line; macOS's redirected launchd
# log files carry no per-line timestamp to diff.
STARVE_WINDOW="${STARVE_WINDOW:-10}"
STARVE_GAP_WARN_SECONDS="${STARVE_GAP_WARN_SECONDS:-150}"
if [ "$PLATFORM" = "linux" ]; then
  # `-o short-unix` timestamps carry sub-second precision (epoch.usec);
  # truncate to whole seconds before the arithmetic gap check below, or a
  # gap like "109.13" fails bash's integer-only `-gt` with a syntax error.
  MAX_RESPAWN_GAP=$(journalctl --user -u ezgha.service --since "${STARVE_WINDOW} minutes ago" -o short-unix --no-pager 2>/dev/null \
    | grep 'respawned ephemeral runner' \
    | awk '{split($1, t, "."); print t[1]}' \
    | sort -n -u \
    | awk 'NR>1{gap=$1-prev; if (gap>max) max=gap} {prev=$1} END{print max+0}')
  RATE_LIMIT_COUNT=$(recent_logs "$STARVE_WINDOW" | grep -c -i 'rate limit' || true)
  info "serve-loop starvation signal (last ${STARVE_WINDOW}m): max respawn-burst gap=${MAX_RESPAWN_GAP:-0}s, rate-limit occurrences=$RATE_LIMIT_COUNT"
  if [ "${MAX_RESPAWN_GAP:-0}" -gt "$STARVE_GAP_WARN_SECONDS" ]; then
    bad "serve-loop starvation: respawn gap ${MAX_RESPAWN_GAP}s exceeds ${STARVE_GAP_WARN_SECONDS}s — ensure_count is being starved (see ez-gh-actions-yrt/g3o)"
    SLOT_PROOF_CRITICAL=$((SLOT_PROOF_CRITICAL + 1))
  fi
else
  warn "serve-loop starvation signal skipped on $PLATFORM (no per-line timestamps in launchd log redirect)"
fi

# --- G. verdict ----------------------------------------------------------
section "verdict"
# Job-level queue counts (fresh-only, from section 10's single job-map
# fetch) — printed for BOTH healthy and unhealthy verdicts so the queue
# state is never hidden behind a green light.
if [ "${JOBLEVEL_QUEUED_COUNT:-0}" -gt 0 ]; then
  echo "  queue: ${JOBLEVEL_QUEUED_COUNT} queued job(s) (oldest ${JOBLEVEL_OLDEST_QUEUED_MIN:-?}m) | ${JOBLEVEL_INPROG_COUNT:-0} in-progress job(s)"
else
  echo "  queue: 0 queued job(s) | ${JOBLEVEL_INPROG_COUNT:-0} in-progress job(s)"
fi
CRITICAL=0
[ "$SERVICE_STATE" != "active" ]            && CRITICAL=$((CRITICAL+1))
[ "$COLIMA_STATUS" = "Stopped" ]            && CRITICAL=$((CRITICAL+1))
# Healthy runners are online AND match the configured name prefix. (Was hardcoded
# `ez-org-`; fixed to use $RUNNER_NAME_PREFIX so Mac's `ez-mac-runner-b-*` fleet
# counts the same as Linux's `ez-org-runner-*` / `ez-runner-b-*`.)
! echo "$RAW" | jq -e --arg pfx "$RUNNER_NAME_PREFIX" '.runners[] | select(.name | startswith($pfx)) | select(.status=="online")' >/dev/null 2>&1 && \
                                          CRITICAL=$((CRITICAL+1))
# Container count gate uses the CONFIGURED count, not a hardcoded 14.
EXPECTED_CONTAINERS="${EXPECTED_CONTAINERS:-${ASSIGNED:-6}}"
[ "${CONTAINER_COUNT:-0}" -lt "$EXPECTED_CONTAINERS" ] && CRITICAL=$((CRITICAL+1))
# LOOP_FAILS is reported as WARN (not CRITICAL) when the fleet is otherwise
# healthy. ensure_count can fail transiently on slot-name collisions (409 from
# GitHub when an existing runner still holds the name) — those recover on the
# next 30s tick once the slot is reconciled. CRITICAL only fires when the
# reconcile is failing AND there are no healthy runners (the loop failure
# actually matters when the fleet is dark). PR #4 (release_stale_slots) will
# fix the underlying collision; until that lands in main, do not fail the
# fleet over a transient reconcile miss.
if [ "$LOOP_FAILS" -gt 3 ]; then
  HEALTHY_RUNNERS=$(echo "$RAW" | jq -r --arg pfx "$RUNNER_NAME_PREFIX" '[.runners[] | select(.name | startswith($pfx)) | select(.status=="online")] | length')
  if [ "${HEALTHY_RUNNERS:-0}" -lt 1 ]; then
    CRITICAL=$((CRITICAL+1))
    bad "ensure_count failed $LOOP_FAILS times in last ${LOOP_WINDOW}m AND no healthy runners"
  else
    warn "ensure_count failed $LOOP_FAILS times in last ${LOOP_WINDOW}m (transient reconcile miss; $HEALTHY_RUNNERS healthy runners online)"
  fi
fi
# real-execution gate: at least one recent job must have succeeded on our fleet
[ "${REAL_ON_FLEET:-0}" -lt 1 ]            && CRITICAL=$((CRITICAL+1))
# canary gate (only when --prove): the live job must have run on our fleet
[ "$PROVE" = "1" ] && [ -z "$CANARY_OK" ]  && CRITICAL=$((CRITICAL+1))
# queue tail gate: oldest fresh queued JOB waiting > QUEUE_TAIL_WARN_MIN means
# saturated/mis-routing. JOB-level (job created_at -> now), not run age — run
# age includes concurrency/staged-gate wait and false-alarmed (2026-07-10).
[ "${QUEUE_TAIL_BAD:-0}" -eq 1 ] && CRITICAL=$((CRITICAL+1))
# per-slot local execution proof gate (section 9): DOWN slots, IDLE-with-
# backlog slots, and serve-loop starvation are the durable enforcement of
# the "22/22 executing" standard — ground truth from docker, not the
# GitHub API, so it cannot be fooled by a rate-limited fleet-state query.
[ "${SLOT_PROOF_CRITICAL:-0}" -gt 0 ] && CRITICAL=$((CRITICAL + SLOT_PROOF_CRITICAL))
# gh_token staleness gate (section 4b): a missing/expired/unreadable App
# installation token means every gh api call above is either failing or
# about to fail with 401 — this is the root cause the whole fleet drained
# over on 2026-07-08 (bead ez-gh-actions-hcu), so it must fail the verdict
# on its own, not just print a warning that's easy to scroll past.
[ "${GH_TOKEN_STALE_CRITICAL:-0}" -gt 0 ] && CRITICAL=$((CRITICAL + GH_TOKEN_STALE_CRITICAL))

if [ "$CRITICAL" -gt 0 ]; then
  bad "fleet unhealthy: $CRITICAL critical check(s) failed"
  echo
  echo "Suggested remediation (platform=$PLATFORM):"
  if [ "$PLATFORM" = "linux" ]; then
    echo "  1. Stop and restart ezgha:  systemctl --user restart ezgha.service"
  elif [ "$PLATFORM" = "macos" ]; then
    echo "  1. Stop and restart ezgha:  launchctl kickstart -k gui/$(id -u)/org.jleechanorg.ezgha"
    echo "     (or reload plist:        launchctl unload ~/Library/LaunchAgents/org.jleechanorg.ezgha.plist && launchctl load -w ~/Library/LaunchAgents/org.jleechanorg.ezgha.plist)"
  else
    echo "  1. Stop and restart ezgha via your platform's service manager"
  fi
  echo "  2. Reset slot file:          rm ~/.config/ezgha/slot_assignments.toml"
  if command -v colima >/dev/null 2>&1; then
    echo "  3. Start colima if down:     colima start"
  elif command -v limactl >/dev/null 2>&1; then
    echo "  3. Start lima if down:       limactl start <name>"
  fi
  echo "  4. Re-run ./doctor.sh --detail after each step"
  exit 1
fi
ok "fleet healthy: $ONLINE/$TOTAL runners online, $BUSY busy, $CONTAINER_COUNT containers up, $LOOP_FAILS loop errors"
exit 0
