digraph gates {
    graph [
        goal="Full validation: holdout + 3 adversarial gates."
        level5="true"
        label="Gates"
        skip_explore="true"
        skip_plan="true"
        skip_implement="true"
    ]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare,  label="Exit"]

    holdout         [type="holdout_eval",        label="Holdout Eval", feature="hello", timeout=600]
    gate_skeptic [
        type="gate_skeptic",
        label="Skeptic (inverted-incentive review)",
        backend_priority="codex,minimax,agy,claude-sonnet",
        prefer_adversarial="true",
        timeout=600
    ]
    adversarial_reviewer [
        type="parallel_reviewer",
        label="Adversarial reviewer (primary + N shadows, density-enforced)",
        prompt="@prompts/slim/review_phase5_shadow.md",
        backend_priority="minimax,agy,codex,claude-sonnet",
        prefer_adversarial="true",
        n_shadows="3",
        gate_strict="true",
        timeout=600
    ]
    gate_es [
        type="gate_es",
        label="/es Evidence Standards",
        backend_priority="codex,minimax,agy,claude-sonnet",
        prefer_adversarial="true",
        gate_strict="true",
        timeout=600
    ]
    gate_er [
        type="gate_er",
        label="/er Evidence Review",
        backend_priority="codex,minimax,agy,claude-sonnet",
        prefer_adversarial="true",
        gate_strict="true",
        timeout=600
    ]
    gate_cs [
        type="gate_code_standards",
        label="/code_standards (ZFC + leveling + RCF)",
        backend_priority="codex,minimax,agy,claude-sonnet",
        prefer_adversarial="true",
        gate_strict="true",
        timeout=600
    ]

    // Bounded fix loop: any reviewer verdict other than success routes here
    // so the run can iterate on the artifact rather than terminating on a
    // first failure (per factory-evolve G2 fix-loop contract).
    fix [
        type="codergen",
        label="Fix & Iterate",
        class="fix",
        prompt="@prompts/slim/fix.md",
        max_visits="3",
        timeout=600
    ]

    start -> holdout
    holdout -> gate_skeptic [condition="outcome=success"]
    holdout -> fix         [condition="outcome!=success"]

    gate_skeptic -> adversarial_reviewer [condition="outcome=success"]
    gate_skeptic -> fix                  [condition="outcome!=success"]

    adversarial_reviewer -> gate_es [condition="outcome=success"]
    adversarial_reviewer -> fix     [condition="outcome!=success"]

    gate_es -> gate_er [condition="outcome=success"]
    gate_es -> fix     [condition="outcome!=success"]

    gate_er -> gate_cs [condition="outcome=success"]
    gate_er -> fix     [condition="outcome!=success"]

    gate_cs -> exit
    fix -> holdout
}
